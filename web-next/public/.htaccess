RewriteEngine On
RewriteBase /

# 1. Force HTTPS and non-www (SEO unification)
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^www\.okane-no-manabi\.jp$ [NC]
RewriteRule ^(.*)$ https://okane-no-manabi.jp/$1 [R=301,L]

# 2. Redirect legacy ?page= query parameters to new paths (301 Permanent)
# Home
RewriteCond %{QUERY_STRING} ^page=home$ [NC]
RewriteRule ^(index\.html)?$ /? [R=301,L]

# Manga
RewriteCond %{QUERY_STRING} ^page=manga$ [NC]
RewriteRule ^(index\.html)?$ /manga/? [R=301,L]

# Quiz
RewriteCond %{QUERY_STRING} ^page=quiz$ [NC]
RewriteRule ^(index\.html)?$ /quiz/? [R=301,L]

# Column List
RewriteCond %{QUERY_STRING} ^page=column$ [NC]
RewriteRule ^(index\.html)?$ /column/? [R=301,L]

# Column Detail (matches ?page=column_detail&id=col_XXX)
RewriteCond %{QUERY_STRING} ^page=column_detail&id=(col_[0-9]+)$ [NC]
RewriteRule ^(index\.html)?$ /column/%1/? [R=301,L]

# Legacy col= parameter
RewriteCond %{QUERY_STRING} ^col=(col_[0-9]+)$ [NC]
RewriteRule ^(index\.html)?$ /column/%1/? [R=301,L]

# QA, About, Diary, Secret, Explore, etc.
RewriteCond %{QUERY_STRING} ^page=qa$ [NC]
RewriteRule ^(index\.html)?$ /qa/? [R=301,L]

RewriteCond %{QUERY_STRING} ^page=about$ [NC]
RewriteRule ^(index\.html)?$ /about/? [R=301,L]

RewriteCond %{QUERY_STRING} ^page=maneta_diary$ [NC]
RewriteRule ^(index\.html)?$ /maneta_diary/? [R=301,L]

RewriteCond %{QUERY_STRING} ^page=money_secret$ [NC]
RewriteRule ^(index\.html)?$ /money_secret/? [R=301,L]

RewriteCond %{QUERY_STRING} ^page=explore.*$ [NC]
RewriteRule ^(index\.html)?$ /explore/? [R=301,L]

RewriteCond %{QUERY_STRING} ^page=privacy$ [NC]
RewriteRule ^(index\.html)?$ /privacy/? [R=301,L]

RewriteCond %{QUERY_STRING} ^page=disclaimer$ [NC]
RewriteRule ^(index\.html)?$ /disclaimer/? [R=301,L]

RewriteCond %{QUERY_STRING} ^page=contact$ [NC]
RewriteRule ^(index\.html)?$ /contact/? [R=301,L]

# 3. Force trailing slash for clean URLs (ensures Apache finds index.html)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !(\.[a-zA-Z0-9]{1,5}|/)$
RewriteRule ^(.*)$ $1/ [R=301,L]

# 4. Serve index.html for directories
DirectoryIndex index.html

# 5. Custom 404 handler
ErrorDocument 404 /404/index.html
